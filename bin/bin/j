#!/bin/bash
# j — Jira CLI shortcuts with team defaults
# Wraps jira-cli (ankitpokhrel). Config: ~/.config/j/config

CONFIG="${XDG_CONFIG_HOME:-$HOME/.config}/j/config"
[ -f "$CONFIG" ] || { echo "Missing config: $CONFIG" >&2; exit 1; }
source "$CONFIG"

usage() {
    cat <<'EOF'
j — Jira workflow shortcuts

CREATE
  j new   "summary" ["description"]     Create a Story assigned to you
  j feat  "summary" ["description"]     Create a Feature assigned to you
  j bug   "summary" ["description"]     Create a Defect Story (High priority)
  j spike "summary" ["description"]     Create a Spike assigned to you
  j sub   "summary" PARENT-KEY          Create a Sub-task under a parent

WORKFLOW
  j todo  KEY                           Move issue to "To Do"
  j start KEY                           Move issue to "In Progress"
  j done  KEY                           Move issue to "Completed"

VIEW
  j mine                                Your current sprint issues
  j all                                 All your open issues
  j view  KEY                           View issue details
  j open  KEY                           Open issue in browser
  j comment KEY "text"                  Add a comment to an issue

SEARCH
  j ls [text]                           List/search issues

Pass-through: j raw <any jira args>    Run raw jira command
EOF
}

create_issue() {
    local type="$1" summary="$2" body="${3:-}" extra_args=("${@:4}")
    [ -z "$summary" ] && { echo "usage: j ${type,,} \"summary\" [\"description\"]" >&2; exit 1; }

    local args=(-p"$PROJECT" -t"$type" -s"$summary" -a"$ASSIGNEE" --no-input)
    for label in "${DEFAULT_LABELS[@]}"; do args+=(-l"$label"); done
    [ -n "$body" ] && args+=(-b"$(printf '%b' "$body")")
    args+=("${extra_args[@]}")

    jira issue create "${args[@]}"
}

case "${1:-}" in
    new)    create_issue "Story"         "$2" "$3" ;;
    feat)   create_issue "Feature"       "$2" "$3" ;;
    bug)    create_issue "Defect Story"  "$2" "$3" -yHigh ;;
    spike)  create_issue "Spike"         "$2" "$3" ;;
    sub)
        [ -z "${3:-}" ] && { echo "usage: j sub \"summary\" PARENT-KEY" >&2; exit 1; }
        create_issue "Sub-task" "$2" "" -P"$3"
        ;;

    todo)   jira issue move "$2" "To Do" ;;
    start)  jira issue move "$2" "In Progress" ;;
    done)   jira issue move "$2" "Completed" ;;

    mine)   jira issue list -p"$PROJECT" -a"$ASSIGNEE" -q"sprint in openSprints()" ;;
    all)    jira issue list -p"$PROJECT" -a"$ASSIGNEE" -s~Completed -s~Discarded -s~Done ;;
    view)    jira issue view "$2" ;;
    open)    jira open "$2" ;;
    comment) jira issue comment add "$2" "$(printf '%b' "$3")" ;;
    ls)     jira issue list -p"$PROJECT" "${@:2}" ;;

    raw)    jira "${@:2}" ;;
    -h|--help|"") usage ;;
    *)      echo "Unknown command: $1 (try j --help)" >&2; exit 1 ;;
esac
